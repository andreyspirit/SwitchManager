<Window x:Class="SwitchManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SwitchManager.ViewModels"
        Title="Switch Ports Control System" 
        Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanMinimize" 
        Background="#F2F2F2">

    <Window.Resources>
        <Style x:Key="PortButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="85"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="DodgerBlue"/>
                                <Setter TargetName="MainBorder" Property="BorderThickness" Value="4"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>

                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="#A5D6A7"/>
                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                                <Setter Property="BorderThickness" Value="4"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                <Setter Property="Background" Value="#FFCCBC"/>
                                <Setter Property="BorderBrush" Value="#D84315"/>
                                <Setter Property="BorderThickness" Value="4"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Type}" Value="Target">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <ItemsControl ItemsSource="{Binding PortGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1.5" CornerRadius="8" 
                                Margin="12" Background="White" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding GroupName}" 
                                           FontSize="20" FontWeight="ExtraBold" 
                                           HorizontalAlignment="Center" Margin="0,5,0,15"
                                           Foreground="#2C3E50"/>

                                <ItemsControl ItemsSource="{Binding Ports}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource PortButtonStyle}">
                                                <TextBlock Text="{Binding Alias}" FontSize="22" FontWeight="Bold"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="#7F8C8D" 
                       Padding="5"
                       FontSize="13"
                       FontStyle="Italic"/>
        </Border>
    </Grid>
</Window>