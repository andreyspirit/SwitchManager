<Window x:Class="SwitchManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SwitchManager.ViewModels"
        Title="Switch Ports Control System" 
        Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanMinimize" 
        Background="#F2F2F2">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <ItemsControl ItemsSource="{Binding PortGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1.5" CornerRadius="8" 
                                Margin="12" Background="White" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding GroupName}" 
                                           FontSize="20" FontWeight="ExtraBold" 
                                           HorizontalAlignment="Center" Margin="0,5,0,15"
                                           Foreground="#2C3E50"/>

                                <ItemsControl ItemsSource="{Binding Ports}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                    CommandParameter="{Binding}"
                                                    Width="180" Height="85" Margin="0,6"
                                                    BorderThickness="4" BorderBrush="Black">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#F8F8F8"/>
                                                        <Setter Property="BorderBrush" Value="#333333"/>
                                                        <Setter Property="Visibility" Value="Visible"/>

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Target">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#A5D6A7"/>
                                                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Background" Value="#FFCCBC"/>
                                                                <Setter Property="BorderBrush" Value="#D84315"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding Alias}" FontSize="22" FontWeight="Bold"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="#7F8C8D" 
                       Padding="5"
                       FontSize="13"
                       FontStyle="Italic"/>
        </Border>
    </Grid>
</Window>