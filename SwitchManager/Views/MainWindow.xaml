<Window x:Class="SwitchManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SwitchManager.ViewModels"
        xmlns:conv="clr-namespace:SwitchManager.Converters"
        Title="Switch Ports Control System" Height="750" Width="1100" 
        ResizeMode="CanMinimize"
        Background="#F4F7F9" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Converter to toggle red background on error messages -->
        <conv:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />

        <Style x:Key="PortButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="8" BorderThickness="3"
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                <Setter Property="Background" Value="#CFD8DC"/>
                                <Setter Property="BorderBrush" Value="#90A4AE"/>
                                <Setter Property="Foreground" Value="#263238"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                                <Setter Property="BorderBrush" Value="#1B5E20"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="4"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsPhysicallyConnected}" Value="False">
                                <Setter Property="Background" Value="#90A4AE"/>
                                <Setter Property="BorderBrush" Value="#546E7A"/>
                                <Setter Property="Foreground" Value="#263238"/>
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding DataContext.IsTargetLinkActive, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}" Value="False">
                                <Setter Property="Background" Value="#B0BEC5"/>
                                <Setter Property="Foreground" Value="#546E7A"/>
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main groups display area -->
        <ScrollViewer Grid.Row="0" Margin="10">
            <ItemsControl ItemsSource="{Binding PortGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Margin="10" Padding="20" Width="220">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Group Header (CNN, BBC...) -->
                                <TextBlock Text="{Binding GroupName}" FontSize="24" FontWeight="Black" 
                                           HorizontalAlignment="Center" Foreground="#2C3E50"/>

                                <!-- Target Port Number display -->
                                <TextBlock Text="{Binding TargetPortNumber, StringFormat='Port {0}'}" 
                                           FontSize="12" Foreground="#7F8C8D" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,2,0,15">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#7F8C8D"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTargetLinkActive}" Value="False">
                                                    <Setter Property="Text" Value="TARGET LINK DOWN"/>
                                                    <Setter Property="Foreground" Value="#C0392B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Button list for Source ports -->
                                <ItemsControl ItemsSource="{Binding Ports}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource PortButtonStyle}"
                                                    Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Alias}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <!-- Dynamic Port Number from JSON -->
                                                    <TextBlock Text="{Binding Number, StringFormat='Port {0}'}" FontSize="11" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar with Dynamic Error highlighting -->
        <Border Grid.Row="1" Padding="15,8" BorderThickness="0,1,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#E9ECEF"/>
                    <Style.Triggers>
                        <!-- Change background to soft red if StatusMessage is not empty -->
                        <DataTrigger Binding="{Binding StatusMessage.Length, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                            <Setter Property="Background" Value="#FDEDEC"/>
                            <Setter Property="BorderBrush" Value="#FADBD8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#7F8C8D"/>
                            <Style.Triggers>
                                <!-- Change text to bold red on error -->
                                <DataTrigger Binding="{Binding StatusMessage.Length, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                    <Setter Property="Foreground" Value="#C0392B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="System Active" HorizontalAlignment="Right" Foreground="#BDC3C7" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>