<Window x:Class="SwitchManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SwitchManager.ViewModels"
        Title="Switch Ports Control System" Height="750" Width="1100" 
        ResizeMode="CanMinimize"
        Background="#F4F7F9" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="PortButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="BorderBrush" Value="#D35400"/>
            <Setter Property="Foreground" Value="White"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="8" BorderThickness="3"
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3498DB"/>
                                <Setter TargetName="MainBorder" Property="BorderThickness" Value="4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#27AE60"/>
                    <Setter Property="BorderBrush" Value="#1E8449"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ExistsOnHardware}" Value="False">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="Opacity" Value="0.3"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Margin="10">
            <ItemsControl ItemsSource="{Binding PortGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Margin="10" Padding="20" Width="220">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding GroupName}" FontSize="24" FontWeight="Black" 
                                           HorizontalAlignment="Center" Foreground="#2C3E50"/>

                                <TextBlock FontSize="15" FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="0,5,0,15">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text">
                                                <Setter.Value>
                                                    <MultiBinding StringFormat="Port {0} {1}">
                                                        <Binding Path="TargetPortNumber" />
                                                        <Binding Path="TargetPortStatus" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="#7F8C8D"/>

                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TargetPortStatus}" Value="connected">
                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TargetPortStatus}" Value="notconnect">
                                                    <Setter Property="Foreground" Value="#C0392B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TargetPortStatus}" Value="disabled">
                                                    <Setter Property="Foreground" Value="#D35400"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TargetPortStatus}" Value="err-disabled">
                                                    <Setter Property="Foreground" Value="#8E44AD"/>
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding ExistsOnHardware}" Value="False">
                                                    <Setter Property="Text" Value="{Binding TargetPortNumber, StringFormat='Port {0} NOT FOUND'}"/>
                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl ItemsSource="{Binding Ports}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,10">
                                                <Button Style="{StaticResource PortButtonStyle}"
                                                        Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Alias}" FontSize="22" FontWeight="Bold"/>
                                                </Button>

                                                <TextBlock FontSize="13" FontWeight="Bold" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text">
                                                                <Setter.Value>
                                                                    <MultiBinding StringFormat="Port {0} {1}">
                                                                        <Binding Path="Number" />
                                                                        <Binding Path="PortStatus" />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Foreground" Value="#7F8C8D"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PortStatus}" Value="connected">
                                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PortStatus}" Value="notconnect">
                                                                    <Setter Property="Foreground" Value="#C0392B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PortStatus}" Value="disabled">
                                                                    <Setter Property="Foreground" Value="#D35400"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding PortStatus}" Value="err-disabled">
                                                                    <Setter Property="Foreground" Value="#8E44AD"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ExistsOnHardware}" Value="False">
                                                                    <Setter Property="Text" Value="{Binding Number, StringFormat='Port {0} NOT FOUND'}"/>
                                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1" Padding="15,8" Background="#FDEDEC" BorderBrush="#FADBD8" BorderThickness="0,2,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="#C0392B" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           VerticalAlignment="Center"/>

                <TextBlock Text="Hardware Manager v1.2" 
                           HorizontalAlignment="Right" 
                           Foreground="#E6B0AA" 
                           FontSize="11" 
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>